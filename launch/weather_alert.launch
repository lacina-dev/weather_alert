<launch>

    <arg name="arg_ns" default="weather_alert"/>

    <!-- Local config overrides (gitignored). Loaded after config.yaml so it
         wins on any key present in both files.
         If config.local.yaml does not exist, copy config.local.example.yaml to create it. -->
    <arg name="local_config" default="$(find weather_alert)/config/config.local.yaml"/>

    <group ns="$(arg arg_ns)">
        <rosparam command="load" file="$(find weather_alert)/config/config.yaml" />
        <rosparam command="load" file="$(arg local_config)" />
        <node name="weather_alert" pkg="weather_alert" type="weather_alert" respawn="true" respawn_delay="10" output="screen">
            <remap from="log_info" to="/nextion/log_info" />
        </node>
    </group>

</launch>
